<resources xmlns:tools="http://schemas.android.com/tools">
  <!-- Base application theme. -->
  <style name="Base.Theme.SafestNotes" parent="Theme.Material3.DayNight.NoActionBar">
    <item name="colorPrimary">@color/brand_purple</item>
    <item name="colorSecondary">@color/brand_purple</item>
    <item name="colorTertiary">@color/brand_purple</item>
    <item name="colorPrimaryDark">@color/brand_purple</item>
    <item name="colorOnPrimary">@color/white</item>
    <item name="android:colorBackground">@color/background_light</item>
    <item name="colorOnBackground">@color/black</item>
    <item name="colorSurface">@color/background_light</item>
    <item name="colorOnSurface">@color/black</item>
    <item name="colorOnSurfaceVariant">@color/text_gray_light</item>
    <item name="colorControlActivated">@color/brand_purple</item>
    <item name="colorControlHighlight">@color/brand_purple</item>
    <item name="popupMenuStyle">@style/ThemeOverlay.SafestNotes.Popup</item>
  </style>

  <style name="ThemeOverlay.SafestNotes.Popup" parent="ThemeOverlay.AppCompat.Light">
    <item name="android:textColor">@color/black</item>
    <item name="android:colorBackground">@color/white</item>
  </style>

  <style name="Theme.SafestNotes" parent="Base.Theme.SafestNotes" />
</resources>
