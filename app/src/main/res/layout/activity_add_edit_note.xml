<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/surface_dark">

        <!-- Top toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/editor_top_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/nav_background" />

        <!-- Thin separator -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/card_border" />

        <!-- Title -->
        <EditText
            android:id="@+id/titleEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.01"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:background="@android:color/transparent"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="14dp"
            android:singleLine="true"
            android:imeOptions="actionNext"
            android:inputType="textCapSentences"
            android:nextFocusDown="@id/richEditor"
            android:nextFocusForward="@id/richEditor" />

        <!-- Separator -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/card_border" />

        <!-- Rich editor — takes all remaining space -->
        <com.tezas.safestnotes.ui.CustomRichEditor
            android:id="@+id/richEditor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/surface_dark"
            android:focusableInTouchMode="true" />

        <!-- Word / char count bar -->
        <TextView
            android:id="@+id/word_count_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:text=""
            android:gravity="end" />

        <!-- TTS playback bar — visible while reading aloud -->
        <LinearLayout
            android:id="@+id/tts_bar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical"
            android:background="@color/nav_background"
            android:visibility="gone">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_volume_up"
                android:tint="@color/purple_light"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Reading aloud…"
                android:textColor="@color/purple_light"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tts_speed_btn"
                android:layout_width="52dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="1×"
                android:textColor="@color/purple_light"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Tap to change speed" />

            <ImageButton
                android:id="@+id/tts_settings_btn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="7dp"
                android:src="@drawable/ic_settings"
                android:tint="@color/text_secondary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="TTS settings" />

            <ImageButton
                android:id="@+id/tts_stop_btn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="6dp"
                android:src="@drawable/ic_close"
                android:tint="@color/text_secondary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Stop reading" />

        </LinearLayout>

        <!-- STT recording / transcribing bar -->
        <LinearLayout
            android:id="@+id/stt_bar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical"
            android:background="@color/nav_background"
            android:visibility="gone">

            <!-- Pulsing record dot -->
            <View
                android:id="@+id/stt_record_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@color/danger_red"
                android:importantForAccessibility="no" />

            <TextView
                android:id="@+id/stt_status_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Recording…"
                android:textColor="@color/danger_red"
                android:textSize="13sp" />

            <ImageButton
                android:id="@+id/stt_stop_btn"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_close"
                android:tint="@color/text_secondary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Stop recording" />

        </LinearLayout>

        <!-- Thin separator above toolbar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/card_border" />

        <!-- Formatting area: small pill handle at the very top (always visible),
             then the scrollable buttons below it. The pill is teardrop-shaped
             and centered horizontally — tapping it or the full-width hit area
             collapses/expands the buttons. -->
        <LinearLayout
            android:id="@+id/editor_toolbar_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/nav_background">

            <!-- Invisible full-width tap zone; pill drawn inside it -->
            <FrameLayout
                android:id="@+id/editor_toolbar_handle"
                android:layout_width="match_parent"
                android:layout_height="18dp"
                android:background="@color/nav_background"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Toggle formatting panel">

                <!-- Pill: 50dp × 14dp, centered, with teardrop shape -->
                <FrameLayout
                    android:layout_width="50dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:background="@drawable/toolbar_handle_pill">

                    <ImageButton
                        android:id="@+id/editor_toolbar_toggle"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_chevron_down"
                        android:tint="@color/text_muted"
                        android:alpha="0.8"
                        android:padding="2dp"
                        android:scaleType="centerInside"
                        android:background="@android:color/transparent"
                        android:contentDescription="Toggle formatting panel" />

                </FrameLayout>

            </FrameLayout>

            <include
                android:id="@+id/editor_toolbar_panel"
                layout="@layout/editor_toolbar"
                android:layout_width="match_parent"
                android:layout_height="48dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Saving overlay — shown while encrypt+save is in progress -->
    <LinearLayout
        android:id="@+id/saving_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC0D0D1A"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/purple_light" />

        <TextView
            android:id="@+id/saving_overlay_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Saving..."
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

    </LinearLayout>

</FrameLayout>
