<?xml version="1.0" encoding="utf-8"?>
<!-- File responsibility: Settings and preference definitions. Feature area: Preferences, editor focus behavior. -->
<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="General">

        <SwitchPreferenceCompat
            app:key="dark_mode"
            app:title="Dark Mode" />

        <!-- Keep focus behavior user-controlled to match new vs existing note expectations. -->
        <SwitchPreferenceCompat
            app:key="pref_autofocus_new_note"
            app:title="Auto-focus on new note"
            app:defaultValue="true" />

        <SwitchPreferenceCompat
            app:key="pref_autofocus_open_note"
            app:title="Auto-focus when opening notes"
            app:defaultValue="false" />

        <ListPreference
            app:key="language"
            app:title="Language"
            app:entries="@array/language_entries"
            app:entryValues="@array/language_values"
            app:defaultValue="en"
            app:useSimpleSummaryProvider="true"/>

    </PreferenceCategory>

    <PreferenceCategory app:title="Security">

        <Preference
            app:key="master_password"
            app:title="Set Master Password" />

    </PreferenceCategory>

</PreferenceScreen>
