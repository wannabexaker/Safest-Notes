<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <!-- Header: label + view-toggle overflow -->
    <LinearLayout
        android:id="@+id/folders_header"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="4dp"
        android:background="?android:colorBackground">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Folders"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <ImageButton
            android:id="@+id/btn_folders_overflow"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_more_vert"
            android:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:contentDescription="View options" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/folders_recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="46dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="80dp" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_folder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_create_new_folder"
        android:tint="@color/white"
        android:backgroundTint="@color/purple_primary"
        android:contentDescription="Add folder" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
