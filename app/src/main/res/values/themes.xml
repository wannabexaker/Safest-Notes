<resources xmlns:tools="http://schemas.android.com/apk/res/android">
  <style name="Base.Theme.SafestNotes" parent="Theme.Material3.DayNight.NoActionBar">
    <!-- Brand -->
    <item name="colorPrimary">@color/purple_primary</item>
    <item name="colorSecondary">@color/purple_light</item>
    <item name="colorTertiary">@color/purple_dim</item>
    <item name="colorPrimaryDark">@color/purple_primary</item>
    <item name="colorOnPrimary">@color/white</item>
    <item name="colorOnSecondary">@color/white</item>

    <!-- Backgrounds -->
    <item name="android:colorBackground">@color/background_obsidian</item>
    <item name="colorOnBackground">@color/text_primary</item>
    <item name="colorSurface">@color/surface_dark</item>
    <item name="colorOnSurface">@color/text_primary</item>
    <item name="colorOnSurfaceVariant">@color/text_secondary</item>
    <item name="colorSurfaceVariant">@color/surface_variant</item>

    <!-- Material3 container tokens — used by dialogs, bottom sheets, chips -->
    <item name="colorSurfaceContainer">@color/surface_container</item>
    <item name="colorSurfaceContainerHigh">@color/surface_container_high</item>
    <item name="colorSurfaceContainerLow">@color/surface_container_low</item>
    <item name="colorSurfaceContainerLowest">@color/background_obsidian</item>

    <!-- BottomNavigationView active indicator -->
    <item name="colorSecondaryContainer">@color/purple_dim</item>
    <item name="colorOnSecondaryContainer">@color/purple_light</item>

    <!-- Controls -->
    <item name="colorControlActivated">@color/purple_primary</item>
    <item name="colorControlHighlight">@color/purple_dim</item>

    <!-- Status bar -->
    <item name="android:statusBarColor">@android:color/transparent</item>
    <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>

    <!-- Explicit window background — eliminates white flash during transitions -->
    <item name="android:windowBackground">@color/background_obsidian</item>

    <!-- Global shape: 14dp rounded for cards/dialogs/buttons -->
    <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.SafestNotes.Medium</item>
    <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.SafestNotes.Large</item>

    <!-- Component overrides -->
    <item name="toolbarStyle">@style/Widget.SafestNotes.Toolbar</item>
    <item name="popupMenuStyle">@style/Widget.SafestNotes.PopupMenu</item>
    <item name="android:popupMenuStyle">@style/Widget.SafestNotes.PopupMenu</item>
    <item name="alertDialogTheme">@style/SafestNotes.AlertDialog</item>
    <item name="floatingActionButtonStyle">@style/Widget.SafestNotes.FAB</item>
  </style>

  <!-- ── Shapes ──────────────────────────────────────────── -->
  <style name="ShapeAppearance.SafestNotes.Medium" parent="ShapeAppearance.Material3.MediumComponent">
    <item name="cornerSize">14dp</item>
  </style>
  <style name="ShapeAppearance.SafestNotes.Large" parent="ShapeAppearance.Material3.LargeComponent">
    <item name="cornerSize">20dp</item>
  </style>

  <!-- ── Toolbar ────────────────────────────────────────── -->
  <style name="Widget.SafestNotes.Toolbar" parent="Widget.Material3.Toolbar">
    <item name="android:background">@color/nav_background</item>
    <item name="titleTextColor">@color/text_primary</item>
    <item name="subtitleTextColor">@color/text_secondary</item>
  </style>

  <!-- ── Popup / context menus ─────────────────────────── -->
  <style name="Widget.SafestNotes.PopupMenu" parent="Widget.Material3.PopupMenu">
    <item name="android:popupBackground">@drawable/bg_popup_menu</item>
    <item name="android:textColor">@color/text_primary</item>
    <item name="android:itemBackground">@android:color/transparent</item>
  </style>

  <!-- ── AlertDialog ───────────────────────────────────── -->
  <style name="SafestNotes.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
    <item name="android:colorBackground">@color/surface_container_high</item>
    <item name="colorOnSurface">@color/text_primary</item>
    <item name="colorPrimary">@color/purple_primary</item>
    <item name="buttonBarPositiveButtonStyle">@style/SafestNotes.DialogButton</item>
    <item name="buttonBarNegativeButtonStyle">@style/SafestNotes.DialogButton.Text</item>
  </style>
  <style name="SafestNotes.DialogButton" parent="Widget.Material3.Button">
    <item name="android:textColor">@color/purple_light</item>
  </style>
  <style name="SafestNotes.DialogButton.Text" parent="Widget.Material3.Button.TextButton">
    <item name="android:textColor">@color/text_secondary</item>
  </style>

  <!-- ── FAB ───────────────────────────────────────────── -->
  <style name="Widget.SafestNotes.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
    <item name="backgroundTint">@color/purple_primary</item>
    <item name="tint">@color/white</item>
  </style>

  <style name="Theme.SafestNotes" parent="Base.Theme.SafestNotes" />

  <!-- ── Note editor activity — slide-up/down transition ───────────── -->
  <style name="Theme.SafestNotes.NoteEditor" parent="Theme.SafestNotes">
    <item name="android:windowAnimationStyle">@style/Animation.SafestNotes.NoteEditor</item>
  </style>

  <style name="Animation.SafestNotes.NoteEditor" parent="@android:style/Animation.Activity">
    <item name="android:activityOpenEnterAnimation">@anim/note_open_enter</item>
    <item name="android:activityOpenExitAnimation">@anim/note_open_exit</item>
    <item name="android:activityCloseEnterAnimation">@anim/note_close_enter</item>
    <item name="android:activityCloseExitAnimation">@anim/note_close_exit</item>
  </style>

</resources>
