<?xml version="1.0" encoding="utf-8"?>
<!--
    Obsidian Dark Purple note card — Samsung Notes / MAUI aesthetic.
    MaterialCardView extends CardView so the adapter's (itemView as CardView) cast still works.
    IDs preserved: noteTitle, notePreview, noteDate, selection_scrim,
                   selection_check, note_drag_handle.
    New IDs: favorite_accent (left 4dp strip), note_star (★ badge).
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:descendantFocusability="blocksDescendants"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface_dark"
    app:strokeWidth="1dp"
    app:strokeColor="@color/card_border">

    <!-- Content row: left accent strip + text block -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="120dp"
        android:orientation="horizontal"
        android:clickable="false"
        android:focusable="false">

        <!-- Left 4dp favorite accent strip -->
        <View
            android:id="@+id/favorite_accent"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/purple_primary"
            android:visibility="gone"
            android:importantForAccessibility="no" />

        <!-- Text content -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="14dp"
            android:clickable="false"
            android:focusable="false">

            <!-- Title -->
            <TextView
                android:id="@+id/noteTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"
                android:clickable="false"
                android:focusable="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/note_lock_icon" />

            <!-- Lock badge — inline, right of title, left of star -->
            <ImageView
                android:id="@+id/note_lock_icon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_lock"
                android:tint="@color/purple_light"
                android:visibility="gone"
                android:alpha="0.9"
                android:clickable="false"
                android:focusable="false"
                android:layout_marginStart="6dp"
                android:contentDescription="Secure note"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@id/note_star"
                app:layout_constraintBaseline_toBaselineOf="@id/noteTitle" />

            <!-- Star badge — ImageView (top-right, only when isFavorite) -->
            <ImageView
                android:id="@+id/note_star"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_star"
                android:tint="@color/favorite_gold"
                android:visibility="gone"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:layout_marginStart="6dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBaseline_toBaselineOf="@id/noteTitle" />

            <!-- Timestamp -->
            <TextView
                android:id="@+id/noteDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:maxLines="1"
                android:ellipsize="end"
                android:clickable="false"
                android:focusable="false"
                android:layout_marginTop="3dp"
                app:layout_constraintTop_toBottomOf="@id/noteTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Content snippet (ID kept as notePreview for adapter compatibility) -->
            <TextView
                android:id="@+id/notePreview"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.35"
                android:maxLines="2"
                android:ellipsize="end"
                android:clickable="false"
                android:focusable="false"
                android:layout_marginTop="6dp"
                app:layout_constraintTop_toBottomOf="@id/noteDate"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <!-- Selection overlay (purple_dim @ 30% alpha) -->
    <View
        android:id="@+id/selection_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/selection_scrim"
        android:visibility="gone"
        android:clickable="false"
        android:focusable="false" />

    <!-- Selection check icon (top-right) -->
    <ImageView
        android:id="@+id/selection_check"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="top|end"
        android:layout_margin="10dp"
        android:src="@drawable/ic_check_circle"
        android:tint="@color/purple_primary"
        android:visibility="gone"
        android:contentDescription="Selected" />

    <!-- Pin badge — ImageView (bottom-left, shown for pinned notes) -->
    <ImageView
        android:id="@+id/note_pin_badge"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="8dp"
        android:src="@drawable/ic_push_pin"
        android:tint="@color/text_muted"
        android:alpha="0.75"
        android:visibility="gone"
        android:importantForAccessibility="no" />

    <!-- Drag handle (bottom-right, hidden by default) -->
    <ImageView
        android:id="@+id/note_drag_handle"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="8dp"
        android:src="@drawable/ic_drag_handle"
        android:tint="@color/text_muted"
        android:visibility="gone"
        android:contentDescription="Drag to reorder" />

</com.google.android.material.card.MaterialCardView>
