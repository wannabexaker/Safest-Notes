<resources xmlns:tools="http://schemas.android.com/tools">
  <!-- Dark theme overrides for SafestNotes. -->
  <style name="Base.Theme.SafestNotes" parent="Theme.Material3.DayNight.NoActionBar">
    <item name="colorPrimary">@color/brand_purple</item>
    <item name="colorSecondary">@color/brand_purple</item>
    <item name="colorTertiary">@color/brand_purple</item>
    <item name="colorPrimaryDark">@color/brand_purple</item>
    <item name="colorOnPrimary">@color/white</item>
    <item name="android:colorBackground">@color/background_dark</item>
    <item name="colorOnBackground">@color/white</item>
    <item name="colorSurface">@color/background_dark</item>
    <item name="colorOnSurface">@color/white</item>
    <item name="colorOnSurfaceVariant">@color/text_gray_dark</item>
    <item name="colorControlActivated">@color/brand_purple</item>
    <item name="colorControlHighlight">@color/brand_purple</item>
    <item name="popupMenuStyle">@style/ThemeOverlay.SafestNotes.Popup</item>
  </style>

  <style name="ThemeOverlay.SafestNotes.Popup" parent="ThemeOverlay.AppCompat.Dark">
    <item name="android:textColor">@color/white</item>
    <item name="android:colorBackground">@color/background_dark</item>
  </style>
</resources>
